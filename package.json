{
  "name": "atelier",
  "version": "0.1.0-m1",
  "private": true,
  "description": "Atelier reference implementation. Self-hostable OSS template for mixed teams of humans + agents to concurrently author one canonical artifact across IDE, browser, and terminal surfaces.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "atelier": "scripts/cli/atelier.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint:yaml": "tsx scripts/lint/yaml-lint.ts",
    "lint:portability": "tsx scripts/lint/portability-lint.ts",
    "atelier": "tsx scripts/cli/atelier.ts",
    "smoke:cli": "tsx scripts/cli/__smoke__/cli.smoke.ts",
    "smoke:sync-jira": "tsx scripts/sync/__smoke__/jira.smoke.ts",
    "smoke:sync-linear": "tsx scripts/sync/__smoke__/linear.smoke.ts",
    "smoke:init": "tsx scripts/cli/__smoke__/init.smoke.ts",
    "smoke:invite": "tsx scripts/cli/__smoke__/invite.smoke.ts",
    "smoke:deploy": "tsx scripts/cli/__smoke__/deploy.smoke.ts",
    "smoke:migration": "tsx scripts/migration/__smoke__/runner.smoke.ts",
    "smoke:endpoint": "tsx scripts/endpoint/__smoke__/endpoint.smoke.ts",
    "smoke:committer": "tsx scripts/endpoint/__smoke__/committer.smoke.ts",
    "smoke:transport": "tsx scripts/endpoint/__smoke__/transport.smoke.ts",
    "smoke:real-client": "tsx scripts/endpoint/__smoke__/real-client.smoke.ts",
    "smoke:broadcast": "tsx scripts/coordination/__smoke__/broadcast.smoke.ts",
    "smoke:lens": "tsx prototype/__smoke__/lens.smoke.ts",
    "smoke:observability": "tsx prototype/__smoke__/observability.smoke.ts",
    "smoke:iaux": "tsx prototype/__smoke__/iaux.smoke.ts",
    "smoke:iaux:dom": "cd prototype && npx playwright test",
    "smoke:sign-in:dom": "cd prototype && npx playwright test --config=playwright.signin.config.ts",
    "smoke:alert-publisher": "tsx scripts/observability/__smoke__/alert-publisher.smoke.ts",
    "alert-publisher": "tsx scripts/observability/alert-publisher.ts",
    "smoke:semantic-contradiction": "tsx scripts/traceability/__smoke__/semantic-contradiction.smoke.ts",
    "semantic-contradiction": "tsx scripts/traceability/semantic-contradiction.ts",
    "smoke:embeddings": "tsx scripts/coordination/__smoke__/embeddings.smoke.ts",
    "smoke:reranker": "tsx scripts/coordination/__smoke__/reranker.smoke.ts",
    "smoke:find_similar": "tsx scripts/endpoint/__smoke__/find_similar.smoke.ts",
    "smoke:eval_harness": "tsx scripts/eval/find_similar/__smoke__/eval-harness.smoke.ts",
    "embed:run": "tsx scripts/coordination/embed-runner.ts",
    "eval:find_similar": "tsx scripts/eval/find_similar/runner.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "gray-matter": "^4.0.3",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
