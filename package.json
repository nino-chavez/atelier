{
  "name": "atelier",
  "version": "0.1.0-m1",
  "private": true,
  "description": "Atelier reference implementation. Self-hostable OSS template for mixed teams of humans + agents to concurrently author one canonical artifact across IDE, browser, and terminal surfaces.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "atelier": "scripts/cli/atelier.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint:yaml": "tsx scripts/lint/yaml-lint.ts",
    "lint:portability": "tsx scripts/lint/portability-lint.ts",
    "atelier": "tsx scripts/cli/atelier.ts",
    "smoke:cli": "tsx scripts/cli/__smoke__/cli.smoke.ts",
    "smoke:endpoint": "tsx scripts/endpoint/__smoke__/endpoint.smoke.ts",
    "smoke:committer": "tsx scripts/endpoint/__smoke__/committer.smoke.ts",
    "smoke:transport": "tsx scripts/endpoint/__smoke__/transport.smoke.ts",
    "smoke:real-client": "tsx scripts/endpoint/__smoke__/real-client.smoke.ts",
    "smoke:broadcast": "tsx scripts/coordination/__smoke__/broadcast.smoke.ts",
    "smoke:lens": "tsx prototype/__smoke__/lens.smoke.ts",
    "smoke:embeddings": "tsx scripts/coordination/__smoke__/embeddings.smoke.ts",
    "smoke:find_similar": "tsx scripts/endpoint/__smoke__/find_similar.smoke.ts",
    "smoke:eval_harness": "tsx scripts/eval/find_similar/__smoke__/eval-harness.smoke.ts",
    "embed:run": "tsx scripts/coordination/embed-runner.ts",
    "eval:find_similar": "tsx scripts/eval/find_similar/runner.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "gray-matter": "^4.0.3",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
