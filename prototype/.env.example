# Atelier prototype environment template.
#
# Copy to `.env.local` and fill in values:
#   cp prototype/.env.example prototype/.env.local
#
# .env.local is gitignored; .env.example is committed. Both Next.js
# (auto-loads .env.local from this directory) and the route handlers
# read these values via process.env at request time.

# -----------------------------------------------------------------------
# Required for the MCP endpoint at /api/mcp + /oauth/api/mcp
# -----------------------------------------------------------------------

# Postgres connection string for the coordination datastore.
# Local-bootstrap default points at the Supabase CLI's local Postgres.
# For cloud deploys swap the host + password.
ATELIER_DATASTORE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# OIDC issuer URL for bearer-token validation (per ADR-028 + ARCH §7.1).
# Local Supabase Auth issuer:
ATELIER_OIDC_ISSUER=http://127.0.0.1:54321/auth/v1

# JWT audience claim Supabase Auth issues by default. BYO IdPs may
# issue a different audience; override here when the issuer differs.
ATELIER_JWT_AUDIENCE=authenticated

# Optional: explicit override for the registration_endpoint URL emitted
# in OAuth discovery (per the substrate split, PR #14). When unset, the
# lib derives an absolute URL from the request origin. Adopters with a
# real RFC 7591 DCR endpoint at their auth provider point at it here.
# ATELIER_OAUTH_REGISTRATION_ENDPOINT=https://auth.example.com/oauth/register

# Optional: full deploy URL of the endpoint. When set, registration_endpoint
# falls back to `<endpoint-url>/oauth/register` if the per-request derivation
# is unavailable (rare; mostly test code paths).
# ATELIER_ENDPOINT_URL=https://atelier.example.com

# -----------------------------------------------------------------------
# Required for find_similar (per ADR-041)
# -----------------------------------------------------------------------

# OpenAI-compatible embeddings provider key. Defaults target OpenAI's
# `text-embedding-3-small` per .atelier/config.yaml. Adopters using a
# different provider override base_url + api_key_env in config.yaml.
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------
# Required for /atelier lens UI (per ADR-028 SSR cookie reads)
# -----------------------------------------------------------------------

# Supabase project URL (cloud Supabase URL or local API URL). Used by
# the @supabase/ssr client to read the auth cookie on /atelier requests.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
