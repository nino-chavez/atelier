# Atelier prototype environment template.
#
# Copy to `.env.local` and fill in values:
#   cp prototype/.env.example prototype/.env.local
#
# .env.local is gitignored; .env.example is committed. Both Next.js
# (auto-loads .env.local from this directory) and the route handlers
# read these values via process.env at request time.
#
# Atelier reads canonical Vercel + Supabase + Next.js env-var names
# (POSTGRES_URL, NEXT_PUBLIC_SUPABASE_URL, etc.) so Vercel's native
# Supabase Marketplace integration auto-provisions everything correctly.
# Every read site has a fallback chain that still accepts the legacy
# ATELIER_*-prefixed names from earlier versions; existing operator
# setups keep working through the deprecation window.

# -----------------------------------------------------------------------
# Required for the MCP endpoint at /api/mcp + /oauth/api/mcp
# -----------------------------------------------------------------------

# Postgres connection string for the coordination datastore.
# Local-bootstrap default points at the Supabase CLI's local Postgres.
# For cloud deploys this is the Supabase Session-mode pooler URL
# (port 5432 on aws-0-<region>.pooler.supabase.com), NOT the direct
# db.<ref>.supabase.co host -- Vercel Functions can't reach the direct
# host over IPv6. Vercel's native Supabase integration provisions this
# automatically.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Direct (non-pooling) Postgres URL for migrations and schema work.
# Required because the transaction pooler can't run advisory locks or
# session-scoped statements (CREATE INDEX CONCURRENTLY etc.). Local
# bootstrap reuses the same URL since the local Supabase Postgres has
# no separate pooler.
POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# (Legacy alias still accepted via the fallback chain.)
# ATELIER_DATASTORE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------
# Bearer-token validation (per ADR-028 + ARCH §7.1)
# -----------------------------------------------------------------------
#
# Atelier derives the OIDC issuer from NEXT_PUBLIC_SUPABASE_URL
# (Supabase Auth lives at `<url>/auth/v1`) and defaults the JWT audience
# to "authenticated" (Supabase Auth default). No explicit issuer/audience
# env is needed in the canonical setup.
#
# BYO IdPs that don't follow the Supabase shape may override:
#   ATELIER_OIDC_ISSUER=https://auth.example.com
#   ATELIER_JWT_AUDIENCE=my-app

# -----------------------------------------------------------------------
# Public site URL (magic-link redirects, OAuth discovery)
# -----------------------------------------------------------------------

# Canonical: NEXT_PUBLIC_SITE_URL (community Next.js convention).
# Vercel runtime also exposes VERCEL_URL automatically (bare host); the
# fallback chain prefixes `https://` and uses it when SITE_URL is unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Legacy aliases still accepted via the fallback chain.)
# ATELIER_PUBLIC_URL=https://atelier.example.com
# ATELIER_ENDPOINT_URL=https://atelier.example.com

# Optional: explicit override for the registration_endpoint URL emitted
# in OAuth discovery (per the substrate split, PR #14). When unset, the
# lib derives an absolute URL from the request origin. Adopters with a
# real RFC 7591 DCR endpoint at their auth provider point at it here.
# ATELIER_OAUTH_REGISTRATION_ENDPOINT=https://auth.example.com/oauth/register

# -----------------------------------------------------------------------
# Required for find_similar (per ADR-041)
# -----------------------------------------------------------------------

# OpenAI-compatible embeddings provider key. Defaults target OpenAI's
# `text-embedding-3-small` per .atelier/config.yaml. Adopters using a
# different provider override base_url + api_key_env in config.yaml.
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------
# Required for /atelier lens UI (per ADR-028 SSR cookie reads)
# -----------------------------------------------------------------------

# Supabase project URL (cloud Supabase URL or local API URL). Used by
# the @supabase/ssr client to read the auth cookie on /atelier requests
# AND to derive the OIDC issuer for bearer validation.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase publishable key (post-2025 Supabase API key paradigm;
# `sb_publishable_*` values). Used by the browser Supabase client and
# the @supabase/ssr SSR helper. The legacy NEXT_PUBLIC_SUPABASE_ANON_KEY
# slot accepts the same value as a drop-in via the fallback chain.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# (Legacy alias still accepted via the fallback chain.)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# -----------------------------------------------------------------------
# Server-side admin operations (atelier invite, atelier datastore --seed)
# -----------------------------------------------------------------------

# Supabase admin URL + service-role key. Required only for operator
# scripts that hit the Auth admin API (invite users, seed composers).
# Routine MCP tools never use the service role.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
