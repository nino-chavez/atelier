# Atelier prototype environment template (canonical Supabase + Vercel shape).
#
# Copy to `.env.local` and fill in values:
#   cp prototype/.env.example prototype/.env.local
#
# .env.local is gitignored; .env.example is committed. Both Next.js
# (auto-loads .env.local from this directory) and the route handlers
# read these values via process.env at request time.
#
# Recommended provisioning path (Vercel deploy):
#   Install the Vercel-Supabase Marketplace integration on your Vercel
#   project. The integration auto-provisions every variable below
#   except OPENAI_API_KEY. See docs/user/tutorials/first-deploy.md.
#
# Per the canonical-rebuild PR (BRD-OPEN-QUESTIONS section 31, 2026-05-04)
# the ATELIER_DATASTORE_URL / ATELIER_OIDC_ISSUER / ATELIER_JWT_AUDIENCE /
# ATELIER_PUBLIC_URL / ATELIER_ENDPOINT_URL env vars are RETIRED. If your
# operator runbook still references them, switch to the canonical names
# below.

# -----------------------------------------------------------------------
# Postgres connection
# -----------------------------------------------------------------------

# Pooler URL (used by /api/mcp at runtime + scripts at operator time).
# Vercel-Supabase Marketplace integration sets this automatically.
# Local-bootstrap default points at the Supabase CLI's local Postgres.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Direct connection URL (no pooler). Required for migrations and any
# session-pinned operations. Vercel-Supabase Marketplace integration
# sets this automatically. Local-bootstrap shares the same value.
POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------
# Supabase Auth (drives /atelier SSR cookie reads + /api/mcp JWKS verify)
# -----------------------------------------------------------------------

# Supabase project URL. The OIDC issuer derives as `${URL}/auth/v1`;
# the JWKS endpoint at `${URL}/auth/v1/.well-known/jwks.json` is what
# the MCP route validates bearer tokens against.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Publishable / anon key. Late-2025 Supabase ships sb_publishable_*
# keys; the integration may set this as either NEXT_PUBLIC_SUPABASE_-
# PUBLISHABLE_KEY (new paradigm) or NEXT_PUBLIC_SUPABASE_ANON_KEY
# (legacy name). The lens code accepts either; both contain the
# publishable value.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Required by operator scripts (invite-composer,
# seed-composer, alert-publisher) that mutate the Auth user table.
# NEVER expose to the browser; this key bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------
# Public URL (drives invite redirects + OAuth discovery registration_endpoint)
# -----------------------------------------------------------------------

# Public deploy URL. Vercel auto-provisions VERCEL_URL in production
# (without protocol); the prototype derives `https://${VERCEL_URL}`
# from it. NEXT_PUBLIC_SITE_URL is the explicit override and is what
# operators set when they have a custom domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3030

# -----------------------------------------------------------------------
# find_similar (per ADR-041)
# -----------------------------------------------------------------------

# OpenAI-compatible embeddings provider key. Defaults target OpenAI's
# text-embedding-3-small per .atelier/config.yaml. Adopters using a
# different provider override base_url + api_key_env in config.yaml.
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------
# Optional: dev-only auth bypass for local smoke fixtures
# -----------------------------------------------------------------------

# Set both to opt into the stub-bearer path used by older smokes.
# Real deployments NEVER set ATELIER_ALLOW_DEV_BEARER. Note: post the
# canonical rebuild, the dev-bearer path no longer reaches the lens
# VM loaders (PostgREST validates JWTs); use real Supabase Auth
# sign-in for end-to-end tests.
# ATELIER_ALLOW_DEV_BEARER=true
# ATELIER_DEV_BEARER=stub:sub-some-composer

# -----------------------------------------------------------------------
# Optional: explicit OAuth Dynamic Client Registration endpoint
# -----------------------------------------------------------------------

# Adopters with a real RFC 7591 DCR endpoint at their auth provider
# point at it here. The default emits `<site-url>/oauth/register` (a
# 405 stub per ARCH 7.9 + ADR-028 — Atelier does not implement DCR).
# ATELIER_OAUTH_REGISTRATION_ENDPOINT=https://auth.example.com/oauth/register

# -----------------------------------------------------------------------
# Inbound webhook secrets (S12 — closes ARCH §6.2.2.1 + §6.4.2 + §716 mandate)
# -----------------------------------------------------------------------

# Required by /api/webhooks/github. Generate via `openssl rand -hex 32`
# and paste into the GitHub webhook configuration's "Secret" field.
# When unset, the route returns HTTP 500 (fail-closed); never accepts
# unsigned requests.
GITHUB_WEBHOOK_SECRET=

# Required by /api/webhooks/figma. Generate via `openssl rand -hex 32`
# and paste into the Figma webhook configuration's "passcode" field.
# Same fail-closed semantics as the GitHub secret.
FIGMA_WEBHOOK_SECRET=
